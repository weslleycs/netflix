generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  movies    Movie[]
  series    Serie[]
  seasons   Season[]

  @@map("users")
}

model Movie {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  imageUrl    String
  genre       Genre
  userId      Int?
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("movies")
}

enum Genre {
  ACTION
  ADVENTURE
  COMEDY
  DRAMA
  HORROR
  THRILLER
  ROMANCE
  SCIFI
  FANTASY
  ANIMATION
  DOCUMENTARY
  CRIME
  MYSTERY
  FAMILY
  BIOGRAPHY
  WAR
  MUSICAL
}

model Serie {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  imageUrl    String
  genre       Genre
  userId      Int?

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")

  user    User?    @relation(fields: [userId], references: [id])
  seasons Season[]

  @@map("series")
}

model Season {
  id        Int       @id @default(autoincrement())
  season    Int
  episodes  Int
  userId    Int?
  serieId   Int
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")

  user  User? @relation(fields: [userId], references: [id])
  serie Serie @relation(fields: [serieId], references: [id])

  @@map("seasons")
}
