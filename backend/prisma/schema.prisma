generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     Role   @default(USER)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("users")
}

model Movie {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  imageUrl    String
  genre       GenreMovie

  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")

  @@map("movies")
}

enum GenreMovie {
  ACTION
  ADVENTURE
  COMEDY
  DRAMA
  HORROR
  THRILLER
  ROMANCE
  SCIFI
  FANTASY
  ANIMATION
  DOCUMENTARY
  CRIME
  MYSTERY
  FAMILY
  BIOGRAPHY
  WAR
  MUSICAL
}


