generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id               Int       @id @default(autoincrement())
  name             String
  password         String
  email            String    @unique
  active           Boolean?  @default(true)
  session          String?
  refreshToken     String?
  codResetPassword String?
  createdAt        DateTime? @default(now())
  updatedAt        DateTime  @default(now())

  movies  movies[]
  series  series[]
  rates   rates[]
  coments coments[]
}

model movies {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?
  userId      Int?
  createdAt   DateTime? @default(now())
  updatedAt   DateTime  @default(now())

  user         users?          @relation(fields: [userId], references: [id])
  seasons      seasons[]
  moviesGenres movies_genres[]
  rates        rates[]
  coments      coments[]
}

model series {
  id           Int             @id @default(autoincrement())
  title        String
  description  String
  imageUrl     String
  userId       Int?
  createdAt    DateTime?       @default(now())
  updatedAt    DateTime        @default(now())
  user         users?          @relation(fields: [userId], references: [id])
  seriesGenres series_genres[]
  rates        rates[]
  coments      coments[]
}

model seasons {
  id        Int       @id @default(autoincrement())
  seasons   Int
  episodes  Int
  seriesId  Int
  createdAt DateTime? @default(now())
  updatedAt DateTime  @default(now())

  movies movies @relation(fields: [seriesId], references: [id])
}

model genres {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  description  String?
  createdAt    DateTime?       @default(now())
  updatedAt    DateTime        @default(now())
  seriesGenres series_genres[]
  moviesGenres movies_genres[]

  @@index([name])
}

model series_genres {
  id        Int       @id @default(autoincrement())
  genreId   Int
  serieId   Int
  createdAt DateTime? @default(now())
  updatedAt DateTime  @default(now())
  genre     genres    @relation(fields: [genreId], references: [id])
  serie     series    @relation(fields: [serieId], references: [id])
}

model movies_genres {
  id        Int       @id @default(autoincrement())
  genreId   Int
  moviesId  Int
  createdAt DateTime? @default(now())
  updatedAt DateTime  @default(now())
  genre     genres    @relation(fields: [genreId], references: [id])
  movie     movies    @relation(fields: [moviesId], references: [id])
}

model rates {
  id        Int       @id @default(autoincrement())
  rate      Int
  userId    Int
  serieId   Int?
  movieId   Int?
  createdAt DateTime? @default(now())
  updatedAt DateTime  @default(now())

  user  users   @relation(fields: [userId], references: [id])
  serie series? @relation(fields: [serieId], references: [id])
  movie movies? @relation(fields: [movieId], references: [id])
}

model coments {
  id        Int       @id @default(autoincrement())
  coment    String
  userId    Int
  serieId   Int?
  movieId   Int?
  createdAt DateTime? @default(now())
  updatedAt DateTime  @default(now())

  user  users   @relation(fields: [userId], references: [id])
  serie series? @relation(fields: [serieId], references: [id])
  movie movies? @relation(fields: [movieId], references: [id])
}
