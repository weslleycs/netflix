generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id               Int      @id @default(autoincrement())
  name             String
  password         String
  email            String   @unique
  active           Boolean? @default(true)
  session          String?
  refreshToken     String?
  codResetPassword String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now())

  movies   movies[]
  series   series[]
  rates    rates[]
  comments comment[]
}

model movies {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?
  userId      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  user         users?          @relation(fields: [userId], references: [id])
  moviesGenres movies_genres[]
  rates        rates[]
  comments     comment[]
}

model series {
  id           Int             @id @default(autoincrement())
  title        String
  description  String?
  imageUrl     String?
  userId       Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now())
  user         users?          @relation(fields: [userId], references: [id])
  seriesGenres series_genres[]
  rates        rates[]
  comments     comments[]
  seasons      seasons[]
}

model seasons {
  id        Int      @id @default(autoincrement())
  seasons   Int
  episodes  Int
  seriesId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  series series @relation(fields: [seriesId], references: [id])
}

model genres {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  description  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now())
  seriesGenres series_genres[]
  moviesGenres movies_genres[]

  @@index([name])
}

model series_genres {
  id        Int      @id @default(autoincrement())
  genreId   Int
  serieId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  genre     genres   @relation(fields: [genreId], references: [id])
  serie     series   @relation(fields: [serieId], references: [id])
}

model movies_genres {
  id        Int      @id @default(autoincrement())
  genreId   Int
  movieId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  genre     genres   @relation(fields: [genreId], references: [id])
  movie     movies   @relation(fields: [movieId], references: [id])
}

model rates {
  id        Int      @id @default(autoincrement())
  rate      Int
  userId    Int
  serieId   Int?
  movieId   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user  users   @relation(fields: [userId], references: [id])
  serie series? @relation(fields: [serieId], references: [id])
  movie movies? @relation(fields: [movieId], references: [id])
}

model coments {
  id        Int      @id @default(autoincrement())
  coment    String
  userId    Int
  serieId   Int?
  movieId   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user  users   @relation(fields: [userId], references: [id])
  serie series? @relation(fields: [serieId], references: [id])
  movie movies? @relation(fields: [movieId], references: [id])
}

model comments {
  id        Int      @id @default(autoincrement())
  comment   String
  userId    Int
  serieId   Int?
  movieId   Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  user  users   @relation(fields: [userId], references: [id])
  serie series? @relation(fields: [serieId], references: [id])
  movie movies? @relation(fields: [movieId], references: [id])
}
